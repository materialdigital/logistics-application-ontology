  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A process that is initiated by an agent who intends to carry out a plan to achieve an objective through one or more actions as described in a plan specification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "planned process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_0000005",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A directive information entity that describes an intended process endpoint. When part of a plan specification the concretization is realized in a planned process in which the bearer tries to effect the world so that the process endpoint is achieved."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@language" : "en",
    "@value" : "OBI Plan and Planned Process/Roles Branch"
  }, {
    "@language" : "en",
    "@value" : "OBI_0000217"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "objective specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000033"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_0000007",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A directive information entity that describes an action the bearer will take."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@language" : "en",
    "@value" : "OBI Plan and Planned Process branch"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "action specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000033"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_0000030",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A generically dependent continuant that is about some thing."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@language" : "en",
    "@value" : "OBI_0000142"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
