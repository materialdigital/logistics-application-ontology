        <skos:definition xml:lang="en-us">role held by a material entity when it is a proper part of another material entity or is planned to be a proper part of another material entity</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000106 -->


