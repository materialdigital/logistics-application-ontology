    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000000 -->


    <owl:Class rdf:about="https://w3id.org/pmd/log/LOG_1000000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000412 rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Agreement"/>
        <rdfs:label xml:lang="en">agreement</rdfs:label>
        <skos:definition xml:lang="en">understanding between two or more parties that contains a set of commitments on the part of the parties</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000001 -->


