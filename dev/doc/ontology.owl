        <skos:definition xml:lang="en-us">role played by an asset (engineered system or material artifact) when there is a maintenance strategy prescribing its maintenance process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000105 -->


    <owl:Class rdf:about="https://w3id.org/pmd/log/LOG_1000105">
