        <rdfs:label xml:lang="en">airway</rdfs:label>
        <skos:definition xml:lang="en-us">three-dimensional spatial region that connects one specified location (navigation point) to another at a specified altitude, along which an aircraft may be flown</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000100 -->


    <owl:Class rdf:about="https://w3id.org/pmd/log/LOG_1000100">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000028"/>
