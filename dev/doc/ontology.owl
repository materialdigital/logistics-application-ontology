        <rdfs:label xml:lang="en">shipping route</rdfs:label>
        <skos:definition xml:lang="en-us">way (three-dimensional spatial region) that connects two or more supply chain nodes along which some shipment travels during a transport process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/log/LOG_1000102 -->


    <owl:Class rdf:about="https://w3id.org/pmd/log/LOG_1000102">
