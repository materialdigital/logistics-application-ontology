        <skos:definition xml:lang="en">The aggregate state value is a categorical value specification that specifies value of the aggregate state quality.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0020138 -->


    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0020138">
        <owl:equivalentClass rdf:resource="https://w3id.org/pmd/log/LOG_1000037"/>
